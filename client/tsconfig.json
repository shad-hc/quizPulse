{
  "compilerOptions": {
    "target": "ES2020",
    "rootDir" : "./src",
    "outDir" : "./dist",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    // "baseUrl": "src",
    // "ignoreDeprecations": "6.0"  
  },
  "include": ["src"]
}
